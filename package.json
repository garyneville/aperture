{
  "name": "aperture",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:tokens": "style-dictionary build --config style-dictionary.config.json",
    "build": "npm run build:tokens && node --loader ts-node/esm workflow/build/compile-email.ts && node --loader ts-node/esm workflow/build/assemble.ts",
    "build:email-templates": "node --loader ts-node/esm workflow/build/compile-email.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify:generated": "node --loader ts-node/esm workflow/build/verify-generated.ts",
    "cli:finalize-brief": "node --loader ts-node/esm src/app/run-photo-brief/finalize-brief-cli.ts",
    "cli:example": "npm run cli:finalize-brief -- ./fixtures/sample-forecast.json"
  },
  "bin": {
    "aperture-finalize-brief": "./src/app/run-photo-brief/finalize-brief-cli.ts"
  },
  "devDependencies": {
    "@types/mjml": "^4.7.4",
    "esbuild": "^0.25.0",
    "style-dictionary": "^5.3.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "astronomy-engine": "^2.1.19",
    "meteocons": "^3.0.0-dev",
    "mjml": "^4.18.0"
  }
}
