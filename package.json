{
  "name": "aperture",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:tokens": "style-dictionary build --config style-dictionary.config.json",
    "build": "npm run build:tokens && node --loader ts-node/esm workflow/build/compile-email.ts && node --loader ts-node/esm workflow/build/assemble.ts",
    "build:email-templates": "node --loader ts-node/esm workflow/build/compile-email.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify:generated": "npm run build && git diff --exit-code -- generated/workflow/photography-weather-brief.json src/presenters/email/compiled-layout.generated.ts",
    "verify:workflow": "npm run verify:generated"
  },
  "devDependencies": {
    "@types/mjml": "^4.7.4",
    "esbuild": "^0.25.0",
    "style-dictionary": "^5.3.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "astronomy-engine": "^2.1.19",
    "meteocons": "^3.0.0-dev",
    "mjml": "^4.18.0"
  }
}
